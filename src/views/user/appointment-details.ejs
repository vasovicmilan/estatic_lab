<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/flash-messages") %>
  <h1 class="h3 mb-4">Detalji termina</h1>

  <div class="card" style="max-width: 500px;">
    <div class="card-body">
      <dl class="row mb-0">
        <dt class="col-5 text-muted">Usluga</dt><dd class="col-7"><%= data.appointment.usluga.naziv %></dd>
        <dt class="col-5 text-muted">Trajanje</dt><dd class="col-7"><%= data.appointment.usluga.trajanje %></dd>
        <dt class="col-5 text-muted">Termin</dt><dd class="col-7"><%= data.appointment.termin.pocetak %></dd>
        <dt class="col-5 text-muted">Terapeut</dt><dd class="col-7"><%= data.appointment.terapeut %></dd>
        <dt class="col-5 text-muted">Status</dt><dd class="col-7"><%= data.appointment.status %></dd>
        <dt class="col-5 text-muted">Cena</dt><dd class="col-7"><%= data.appointment.konacnaCena %></dd>
        <% if (data.appointment.napomena) { %><dt class="col-5 text-muted">Napomena</dt><dd class="col-7"><%= data.appointment.napomena %></dd><% } %>
        <% if (data.appointment.razlogOdbijanja) { %><dt class="col-5 text-muted">Razlog odbijanja</dt><dd class="col-7"><%= data.appointment.razlogOdbijanja %></dd><% } %>
        <% if (data.appointment.razlogOtkazivanja) { %><dt class="col-5 text-muted">Razlog otkazivanja</dt><dd class="col-7"><%= data.appointment.razlogOtkazivanja %></dd><% } %>
      </dl>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <a href="<%= data.backUrl %>" class="btn btn-outline-secondary">Nazad</a>
    <% if (data.canCancel) { %>
      <form action="/nalog/termini/<%= data.appointment.id %>/otkazi" method="POST" data-confirm="Da li ste sigurni da želite da otkažete termin?">
        <input type="hidden" name="CSRFToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" class="btn btn-outline-danger">Otkaži termin</button>
      </form>
    <% } %>
  </div>
</main>

<%- include("../includes/footer") %>
