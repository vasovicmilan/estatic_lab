<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/breadcrumbs") %>
  <%- include("../includes/flash-messages") %>

  <h1 class="h3 mb-2 text-center">Paketi</h1>
  <% if (data.subtitle) { %><p class="text-muted text-center mb-4"><%= data.subtitle %></p><% } %>

  <% if (data.packages && data.packages.length > 0) { %>
    <div class="row g-4">
      <% data.packages.forEach(function(pkg) { %>
        <div class="col-md-4">
          <div class="card h-100 <%= pkg.najbolji ? 'border-primary' : '' %>">
            <% if (pkg.slika && pkg.slika.url) { %>
              <img src="<%= pkg.slika.url %>" class="card-img-top" style="height:180px;object-fit:cover;" alt="<%= pkg.naziv %>">
            <% } %>
            <div class="card-body d-flex flex-column">
              <% if (pkg.oznaka) { %><span class="badge bg-primary mb-2 align-self-start"><%= pkg.oznaka %></span><% } %>
              <h3 class="h5"><%= pkg.naziv %></h3>
              <p class="text-muted small flex-grow-1"><%= pkg.kratakOpis %></p>
              <ul class="small text-muted">
                <% (pkg.stavke || []).forEach(function(s) { %><li><%= s %></li><% }) %>
              </ul>
              <div class="d-flex justify-content-between align-items-center mt-2">
                <strong><%= pkg.cena %></strong>
                <a href="/paketi/<%= pkg.slug %>" class="btn btn-outline-primary btn-sm">Detalji</a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <%- include("../includes/pagination", { pagination: data.pagination }) %>
  <% } else { %>
    <p class="text-center text-muted">Trenutno nema dostupnih paketa.</p>
  <% } %>
</main>

<%- include("../includes/footer") %>
