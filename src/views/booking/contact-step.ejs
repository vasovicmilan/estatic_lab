<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/breadcrumbs") %>
  <%- include("../includes/flash-messages") %>

  <div class="mb-4">
    <div class="progress" style="height: 6px;">
      <div class="progress-bar" style="width: 75%"></div>
    </div>
    <p class="text-muted small mt-1">Korak 3 od 4 - Vasi podaci</p>
  </div>

  <div class="row">
    <div class="col-md-7">
      <% if (data.errors && data.errors.general) { %><div class="alert alert-danger"><%= data.errors.general %></div><% } %>

      <form action="/zakazivanje/potvrda" method="POST">
        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
        <input type="text" name="nickname" class="d-none" tabindex="-1" autocomplete="off">

        <input type="hidden" name="serviceSlug" value="<%= data.service.slug %>">
        <input type="hidden" name="serviceId" value="<%= data.service.id %>">
        <input type="hidden" name="servicePackageId" value="<%= data.variant.id %>">
        <input type="hidden" name="startTime" value="<%= data.slot.startTime %>">
        <input type="hidden" name="employeeId" value="<%= data.slot.employeeId || '' %>">

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label class="form-label">Ime <span class="text-danger">*</span></label>
            <input type="text" name="firstName" class="form-control" value="<%= (typeof formData !== 'undefined' && formData.firstName) || data.prefill.firstName %>" required>
            <% if (data.errors && data.errors.firstName) { %><div class="text-danger small mt-1"><%= data.errors.firstName %></div><% } %>
          </div>
          <div class="col-md-6">
            <label class="form-label">Prezime</label>
            <input type="text" name="lastName" class="form-control" value="<%= (typeof formData !== 'undefined' && formData.lastName) || data.prefill.lastName %>">
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label class="form-label">Email <span class="text-danger">*</span></label>
            <input type="email" name="email" class="form-control" value="<%= (typeof formData !== 'undefined' && formData.email) || data.prefill.email %>" <%= data.isLoggedIn ? 'readonly' : '' %> required>
            <% if (data.errors && data.errors.email) { %><div class="text-danger small mt-1"><%= data.errors.email %></div><% } %>
          </div>
          <div class="col-md-6">
            <label class="form-label">Telefon <span class="text-danger">*</span></label>
            <input type="text" name="phone" class="form-control" value="<%= (typeof formData !== 'undefined' && formData.phone) || data.prefill.phone %>" required>
            <% if (data.errors && data.errors.phone) { %><div class="text-danger small mt-1"><%= data.errors.phone %></div><% } %>
          </div>
        </div>

        <% if (!data.isLoggedIn) { %>
          <p class="text-muted small">
            Ako nemate nalog, automatski cemo vam kreirati jedan da biste mogli da pratite vas termin - poslacemo vam email sa uputstvom.
          </p>
        <% } %>

        <div class="mb-3">
          <label class="form-label">Napomena</label>
          <textarea name="note" class="form-control" rows="3"><%= (typeof formData !== 'undefined' && formData.note) || '' %></textarea>
        </div>

        <% if (data.couponFieldEnabled) { %>
          <div class="mb-3">
            <label class="form-label">Kod kupona</label>
            <input type="text" name="couponCode" class="form-control text-uppercase" value="<%= (typeof formData !== 'undefined' && formData.couponCode) || '' %>">
          </div>
        <% } %>

        <button type="submit" class="btn btn-primary btn-lg w-100">Potvrdi zakazivanje</button>
      </form>
    </div>

    <div class="col-md-5">
      <div class="card">
        <div class="card-body">
          <h2 class="h6">Pregled termina</h2>
          <dl class="row small mb-0">
            <dt class="col-6 text-muted">Usluga</dt><dd class="col-6"><%= data.service.naziv %></dd>
            <dt class="col-6 text-muted">Varijanta</dt><dd class="col-6"><%= data.variant.naziv %></dd>
            <dt class="col-6 text-muted">Trajanje</dt><dd class="col-6"><%= data.variant.trajanje %> min</dd>
            <dt class="col-6 text-muted">Termin</dt><dd class="col-6"><%= new Date(data.slot.startTime).toLocaleString('sr-RS') %></dd>
            <dt class="col-6 text-muted">Cena</dt><dd class="col-6"><%= data.variant.cena %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include("../includes/footer") %>
