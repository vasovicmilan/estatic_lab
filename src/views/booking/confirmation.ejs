<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/flash-messages") %>

  <div class="row justify-content-center">
    <div class="col-md-7 text-center">
      <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
      <h1 class="h3 mt-3">Termin je uspešno zakazan!</h1>
      <p class="text-muted">Poslali smo vam email potvrdu na navedenu adresu.</p>

      <% if (data.accountJustCreated) { %>
        <div class="alert alert-info text-start mt-4">
          <strong>Napravili smo vam nalog</strong> da biste mogli da pratite ovaj i buduće termine.
          Proverite vaš email — poslali smo vam link za postavljanje lozinke.
        </div>
      <% } %>

      <div class="card text-start mt-4">
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-5 text-muted">Usluga</dt><dd class="col-7"><%= data.appointment.usluga.naziv %></dd>
            <dt class="col-5 text-muted">Termin</dt><dd class="col-7"><%= data.appointment.termin.pocetak %></dd>
            <dt class="col-5 text-muted">Trajanje</dt><dd class="col-7"><%= data.appointment.usluga.trajanje %></dd>
            <dt class="col-5 text-muted">Terapeut</dt><dd class="col-7"><%= data.appointment.terapeut %></dd>
            <dt class="col-5 text-muted">Status</dt><dd class="col-7"><%= data.appointment.status %></dd>
            <dt class="col-5 text-muted">Cena</dt><dd class="col-7"><%= data.appointment.konacnaCena %></dd>
          </dl>
        </div>
      </div>

      <a href="/" class="btn btn-primary mt-4">Nazad na početnu</a>
    </div>
  </div>
</main>

<%- include("../includes/footer") %>
