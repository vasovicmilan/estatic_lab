<%- include("_layout", {
  title: "Novi termin dodeljen",
  preheader: "Dodeljen vam je novi termin",
  body: `
    <h1 style="font-size:20px; color:#333; margin:0 0 16px;">Novi termin dodeljen${typeof firstName !== 'undefined' && firstName ? ', ' + firstName : ''}</h1>
    <p style="font-size:14px; color:#555; line-height:1.6; margin:0 0 16px;">
      Dodeljen vam je termin koji je prethodno bio kod drugog terapeuta ili nedodeljen.
    </p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f9f7f5; border-radius:6px; margin:0 0 16px;">
      <tr><td style="padding:16px; font-size:14px; color:#333;">
        <strong>Klijent:</strong> ${appointment.korisnik?.ime || "-"}<br>
        <strong>Usluga:</strong> ${appointment.usluga?.naziv || "-"}<br>
        <strong>Termin:</strong> ${appointment.termin?.pocetak || "-"}
      </td></tr>
    </table>
    <p style="text-align:center; margin:32px 0;">
      <a href="${manageUrl}" style="background-color:#7a5c3e; color:#ffffff; padding:12px 28px; border-radius:4px; text-decoration:none; font-size:14px; font-weight:bold; display:inline-block;">Pregledaj termin</a>
    </p>
  `
}) %>