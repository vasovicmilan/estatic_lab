<%- include("_layout", {
  title: "Nova kontakt poruka",
  preheader: "Stigla je nova poruka sa kontakt forme",
  body: `
    <h1 style="font-size:20px; color:#333; margin:0 0 16px;">Nova kontakt poruka</h1>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f9f7f5; border-radius:6px; margin:0 0 16px;">
      <tr><td style="padding:16px; font-size:14px; color:#333;">
        <strong>Ime:</strong> ${contact.firstName || ""} ${contact.lastName || ""}<br>
        <strong>Email:</strong> ${contact.email || "-"}<br>
        <strong>Poruka:</strong><br>${contact.message || "-"}
      </td></tr>
    </table>
    <p style="text-align:center; margin:32px 0;">
      <a href="${adminUrl}" style="background-color:#7a5c3e; color:#ffffff; padding:12px 28px; border-radius:4px; text-decoration:none; font-size:14px; font-weight:bold; display:inline-block;">Pregledaj u admin panelu</a>
    </p>
  `
}) %>