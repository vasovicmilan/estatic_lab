<form action="<%= data.formAction %>" method="POST" enctype="multipart/form-data">
  <input type="hidden" name="_method" value="<%= data.isEdit ? 'PUT' : 'POST' %>">
  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Osnovni podaci</h2></div>
    <div class="card-body">
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Naziv <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" value="<%= data.formData.name || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Slug <span class="text-danger">*</span></label>
          <input type="text" name="slug" class="form-control" value="<%= data.formData.slug || '' %>" required>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Kratak opis</label>
        <input type="text" name="shortDescription" class="form-control" value="<%= data.formData.shortDescription || '' %>">
      </div>

      <div class="mb-3">
        <label class="form-label">Opis <span class="text-danger">*</span></label>
        <textarea name="description" class="form-control" rows="4" required><%= data.formData.description || '' %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Slika</label>
        <input type="file" name="packageImage" class="form-control" accept="image/*">
        <% if (data.formData.image && data.formData.image.img) { %><img src="<%= data.formData.image.img %>" class="mt-2 rounded" width="120"><% } %>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label">Cena (RSD) <span class="text-danger">*</span></label>
          <input type="number" name="totalPrice" class="form-control" value="<%= data.formData.totalPrice || 0 %>" min="0" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Stara cena (opciono)</label>
          <input type="number" name="basePrice" class="form-control" value="<%= data.formData.basePrice || '' %>" min="0">
        </div>
        <div class="col-md-4">
          <label class="form-label">Oznaka</label>
          <input type="text" name="badge" class="form-control" value="<%= data.formData.badge || '' %>" placeholder="npr. NAJPOPULARNIJE">
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Redosled prikaza</label>
          <input type="number" name="order" class="form-control" value="<%= data.formData.order || 0 %>" min="0">
        </div>
        <div class="col-md-6 d-flex align-items-end gap-4">
          <div class="form-check">
            <input type="checkbox" name="isBest" value="true" class="form-check-input" id="isBestCheck" <%= data.formData.isBest ? 'checked' : '' %>>
            <label class="form-check-label" for="isBestCheck">Najbolji izbor</label>
          </div>
          <div class="form-check">
            <input type="checkbox" name="isActive" value="true" class="form-check-input" id="isActiveCheck" <%= data.formData.isActive !== false ? 'checked' : '' %>>
            <label class="form-check-label" for="isActiveCheck">Aktivan</label>
          </div>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Kategorije</label>
          <select name="categories" class="form-select" multiple size="4">
            <% data.categoryOptions.forEach(function(opt) { %>
              <option value="<%= opt.id %>" <%= (data.formData.categories || []).includes(opt.id) ? 'selected' : '' %>><%= opt.naziv %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Tagovi</label>
          <select name="tags" class="form-select" multiple size="4">
            <% data.tagOptions.forEach(function(opt) { %>
              <option value="<%= opt.id %>" <%= (data.formData.tags || []).includes(opt.id) ? 'selected' : '' %>><%= opt.naziv %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Usluge u paketu <span class="text-danger">*</span></h2></div>
    <div class="card-body">
      <p class="text-muted small">Dostupne usluge (kopirajte ID iz padajuće liste u JSON ispod):</p>
      <ul class="small text-muted">
        <% data.serviceOptions.forEach(function(opt) { %><li><code><%= opt.value %></code> — <%= opt.label %></li><% }) %>
      </ul>
      <textarea name="items" class="form-control font-monospace" rows="6" required><%= JSON.stringify(data.formData.items && data.formData.items.length ? data.formData.items : [{ service: "", sessions: 1 }], null, 2) %></textarea>
      <div class="form-text">Format: niz objekata sa <code>service</code> (ID usluge) i <code>sessions</code> (broj seansi).</div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">FAQ</h2></div>
    <div class="card-body">
      <textarea name="faq" class="form-control font-monospace" rows="5"><%= JSON.stringify(data.formData.faq || [], null, 2) %></textarea>
    </div>
  </div>

  <button type="submit" class="btn btn-primary">Sačuvaj</button>
</form>
