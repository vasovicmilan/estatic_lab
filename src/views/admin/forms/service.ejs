<form action="<%= data.formAction %>" method="POST" enctype="multipart/form-data">
  <input type="hidden" name="_method" value="<%= data.isEdit ? 'PUT' : 'POST' %>">
  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Osnovni podaci</h2></div>
    <div class="card-body">
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Naziv <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" value="<%= data.formData.name || '' %>" required>
          <% if (data.errors && data.errors.name) { %><div class="text-danger small mt-1"><%= data.errors.name %></div><% } %>
        </div>
        <div class="col-md-6">
          <label class="form-label">Slug <span class="text-danger">*</span></label>
          <input type="text" name="slug" class="form-control" value="<%= data.formData.slug || '' %>" required>
          <% if (data.errors && data.errors.slug) { %><div class="text-danger small mt-1"><%= data.errors.slug %></div><% } %>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Kratak opis</label>
        <textarea name="shortDescription" class="form-control" rows="2" maxlength="300"><%= data.formData.shortDescription || '' %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Dugi opis</label>
        <textarea name="longDescription" class="form-control" rows="5"><%= data.formData.longDescription || '' %></textarea>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Kategorije</label>
          <select name="categories" class="form-select" multiple size="5">
            <% data.categoryOptions.forEach(function(opt) { %>
              <option value="<%= opt.id %>" <%= (data.formData.categories || []).includes(opt.id) ? 'selected' : '' %>><%= opt.naziv %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Tagovi</label>
          <select name="tags" class="form-select" multiple size="5">
            <% data.tagOptions.forEach(function(opt) { %>
              <option value="<%= opt.id %>" <%= (data.formData.tags || []).includes(opt.id) ? 'selected' : '' %>><%= opt.naziv %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Glavna slika <% if (!data.isEdit) { %><span class="text-danger">*</span><% } %></label>
        <input type="file" name="serviceImage" class="form-control" accept="image/*" <%= !data.isEdit ? 'required' : '' %>>
        <% if (data.formData.image && data.formData.image.img) { %><img src="<%= data.formData.image.img %>" class="mt-2 rounded" width="120"><% } %>
      </div>

      <div class="mb-3">
        <label class="form-label">Galerija (dodatne slike)</label>
        <input type="file" name="gallery" class="form-control" accept="image/*" multiple>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label">Podrazumevano trajanje (min)</label>
          <input type="number" name="defaultDuration" class="form-control" value="<%= data.formData.defaultDuration || 60 %>" min="5">
        </div>
        <div class="col-md-4">
          <label class="form-label">Tekst dugmeta za akciju</label>
          <input type="text" name="ctaText" class="form-control" value="<%= data.formData.ctaText || 'Zakaži termin' %>">
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <div class="form-check">
            <input type="checkbox" name="highlight" value="true" class="form-check-input" id="highlightCheck" <%= data.formData.highlight ? 'checked' : '' %>>
            <label class="form-check-label" for="highlightCheck">Istaknuto na početnoj</label>
          </div>
        </div>
      </div>

      <div class="form-check">
        <input type="checkbox" name="isActive" value="true" class="form-check-input" id="isActiveCheck" <%= data.formData.isActive !== false ? 'checked' : '' %>>
        <label class="form-check-label" for="isActiveCheck">Aktivna (vidljiva i dostupna za zakazivanje)</label>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Varijante (paketi usluge) <span class="text-danger">*</span></h2></div>
    <div class="card-body">
      <p class="text-muted small">Svaka varijanta je ono što posetilac bira prilikom zakazivanja (npr. "60 min" vs "90 min").</p>
      <textarea name="packages" class="form-control font-monospace" rows="10" required><%= JSON.stringify(data.formData.packages && data.formData.packages.length ? data.formData.packages : [{ name: "60 minuta", slug: "60-min", sessions: 1, duration: 60, totalPrice: 3000, isActive: true }], null, 2) %></textarea>
      <div class="form-text">Format: niz objekata sa <code>name, slug, sessions, duration (min), totalPrice, basePrice?, badge?, isBest?, isActive</code>.</div>
      <% if (data.errors && data.errors.packages) { %><div class="text-danger small mt-1"><%= data.errors.packages %></div><% } %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Karakteristike</h2></div>
    <div class="card-body">
      <textarea name="features" class="form-control font-monospace" rows="6"><%= JSON.stringify(data.formData.features || [], null, 2) %></textarea>
      <div class="form-text">Format: niz objekata sa <code>name, slug, description, icon?, isActive</code>.</div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Tabela poređenja</h2></div>
    <div class="card-body">
      <div class="mb-2">
        <label class="form-label small">Kolone (odvojeno zarezom)</label>
        <input type="text" name="comparisonColumnsCsv" class="form-control" value="<%= (data.formData.comparisonColumns || []).join(', ') %>">
      </div>
      <textarea name="comparisonTable" class="form-control font-monospace" rows="5"><%= JSON.stringify(data.formData.comparisonTable || [], null, 2) %></textarea>
      <div class="form-text">Format: niz objekata sa <code>label, values: []</code> — broj vrednosti mora odgovarati broju kolona.</div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">FAQ</h2></div>
    <div class="card-body">
      <textarea name="faq" class="form-control font-monospace" rows="6"><%= JSON.stringify(data.formData.faq || [], null, 2) %></textarea>
      <div class="form-text">Format: niz objekata sa <code>question, answer</code>.</div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Terapeuti koji izvode ovu uslugu</h2></div>
    <div class="card-body">
      <select name="employees" class="form-select" multiple size="6">
        <% data.employeeOptions.forEach(function(opt) { %>
          <option value="<%= opt.value %>" <%= (data.formData.employees || []).includes(opt.value) ? 'selected' : '' %>><%= opt.label %></option>
        <% }) %>
      </select>
      <div class="form-text">Ovo određuje ko se nudi prilikom zakazivanja — obavezno za rad kalkulatora dostupnih termina.</div>
    </div>
  </div>

  <button type="submit" class="btn btn-primary">Sačuvaj</button>
</form>
