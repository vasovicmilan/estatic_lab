<form action="<%= data.formAction %>" method="POST">
  <input type="hidden" name="_method" value="<%= data.isEdit ? 'PUT' : 'POST' %>">
  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">

  <div class="card mb-4">
    <div class="card-body">
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Naziv <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" value="<%= data.formData.name || '' %>" required>
          <% if (data.errors && data.errors.name) { %><div class="text-danger small mt-1"><%= data.errors.name %></div><% } %>
        </div>
        <div class="col-md-6">
          <label class="form-label">Slug <span class="text-danger">*</span></label>
          <input type="text" name="slug" class="form-control" value="<%= data.formData.slug || '' %>" required>
          <% if (data.errors && data.errors.slug) { %><div class="text-danger small mt-1"><%= data.errors.slug %></div><% } %>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Domen <span class="text-danger">*</span></label>
          <select name="domain" class="form-select" required>
            <% data.domains.forEach(function(d) { %>
              <option value="<%= d.value %>" <%= data.formData.domain === d.value ? 'selected' : '' %>><%= d.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6 d-flex align-items-end">
          <div class="form-check">
            <input type="checkbox" name="isActive" value="true" class="form-check-input" id="isActiveCheck" <%= data.formData.isActive !== false ? 'checked' : '' %>>
            <label class="form-check-label" for="isActiveCheck">Aktivan</label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <button type="submit" class="btn btn-primary">Sačuvaj</button>
</form>
