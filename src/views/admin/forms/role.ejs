<form action="<%= data.formAction %>" method="POST">
  <input type="hidden" name="_method" value="<%= data.isEdit ? 'PUT' : 'POST' %>">
  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">

  <div class="card mb-4">
    <div class="card-body">
      <div class="mb-3">
        <label class="form-label">Naziv <span class="text-danger">*</span></label>
        <select name="name" class="form-select" required <%= data.isEdit ? 'disabled' : '' %>>
          <option value="admin" <%= data.formData.name === 'admin' ? 'selected' : '' %>>admin</option>
          <option value="employee" <%= data.formData.name === 'employee' ? 'selected' : '' %>>employee</option>
          <option value="user" <%= data.formData.name === 'user' ? 'selected' : '' %>>user</option>
        </select>
        <% if (data.isEdit) { %><input type="hidden" name="name" value="<%= data.formData.name %>"><% } %>
        <% if (data.errors && data.errors.name) { %><div class="text-danger small mt-1"><%= data.errors.name %></div><% } %>
      </div>

      <div class="mb-3">
        <label class="form-label">Opis</label>
        <textarea name="description" class="form-control" rows="2"><%= data.formData.description || '' %></textarea>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Prioritet</label>
          <input type="number" name="priority" class="form-control" value="<%= data.formData.priority || 0 %>" min="0">
        </div>
        <div class="col-md-6 d-flex align-items-end">
          <div class="form-check">
            <input type="checkbox" name="isDefault" value="true" class="form-check-input" id="isDefaultCheck" <%= data.formData.isDefault ? 'checked' : '' %>>
            <label class="form-check-label" for="isDefaultCheck">Podrazumevana rola za nove korisnike</label>
          </div>
        </div>
      </div>

      <label class="form-label">Permisije</label>
      <div class="row g-2 mb-3">
        <% data.availablePermissions.forEach(function(perm) { %>
          <div class="col-md-4">
            <div class="form-check">
              <input
                type="checkbox"
                name="permissions"
                value="<%= perm.value %>"
                class="form-check-input"
                id="perm-<%= perm.value %>"
                <%= (data.formData.permissions || []).includes(perm.value) ? 'checked' : '' %>
              >
              <label class="form-check-label small" for="perm-<%= perm.value %>"><%= perm.label %></label>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <button type="submit" class="btn btn-primary">Sačuvaj</button>
</form>
