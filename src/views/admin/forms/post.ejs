<form action="<%= data.formAction %>" method="POST" enctype="multipart/form-data">
  <input type="hidden" name="_method" value="<%= data.isEdit ? 'PUT' : 'POST' %>">
  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Osnovni podaci</h2></div>
    <div class="card-body">
      <div class="row g-3 mb-3">
        <div class="col-md-8">
          <label class="form-label">Naslov <span class="text-danger">*</span></label>
          <input type="text" name="title" class="form-control" value="<%= data.formData.title || '' %>" required>
          <% if (data.errors && data.errors.title) { %><div class="text-danger small mt-1"><%= data.errors.title %></div><% } %>
        </div>
        <div class="col-md-4">
          <label class="form-label">Slug <span class="text-danger">*</span></label>
          <input type="text" name="slug" class="form-control" value="<%= data.formData.slug || '' %>" required>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Kratak opis <span class="text-danger">*</span></label>
        <textarea name="excerpt" class="form-control" rows="2" maxlength="300" required><%= data.formData.excerpt || '' %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Naslovna slika <% if (!data.isEdit) { %><span class="text-danger">*</span><% } %></label>
        <input type="file" name="coverImage" class="form-control" accept="image/*" <%= !data.isEdit ? 'required' : '' %>>
        <% if (data.formData.coverImage && data.formData.coverImage.img) { %><img src="<%= data.formData.coverImage.img %>" class="mt-2 rounded" width="160"><% } %>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Kategorije</label>
          <select name="categories" class="form-select" multiple size="4">
            <% data.categoryOptions.forEach(function(opt) { %>
              <option value="<%= opt.id %>" <%= (data.formData.categories || []).includes(opt.id) ? 'selected' : '' %>><%= opt.naziv %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Tagovi</label>
          <select name="tags" class="form-select" multiple size="4">
            <% data.tagOptions.forEach(function(opt) { %>
              <option value="<%= opt.id %>" <%= (data.formData.tags || []).includes(opt.id) ? 'selected' : '' %>><%= opt.naziv %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">Autor</label>
          <select name="author" class="form-select">
            <% data.authorOptions.forEach(function(opt) { %>
              <option value="<%= opt.value %>" <%= data.formData.author === opt.value ? 'selected' : '' %>><%= opt.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Status</label>
          <select name="status" class="form-select">
            <% data.statuses.forEach(function(opt) { %>
              <option value="<%= opt.value %>" <%= data.formData.status === opt.value ? 'selected' : '' %>><%= opt.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <div class="form-check">
            <input type="checkbox" name="isIndexable" value="true" class="form-check-input" id="isIndexableCheck" <%= data.formData.isIndexable !== false ? 'checked' : '' %>>
            <label class="form-check-label" for="isIndexableCheck">Dozvoli indeksiranje</label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="h6 mb-0">Sadržaj</h2></div>
    <div class="card-body">
      <textarea name="content" class="form-control font-monospace" rows="14"><%= JSON.stringify(data.formData.content && data.formData.content.length ? data.formData.content : [{ type: "paragraph", text: "" }], null, 2) %></textarea>
      <div class="form-text">
        Dozvoljeni tipovi blokova: <code><%= data.blockTypes.join(", ") %></code>. Svaki blok ima <code>order</code> (redosled) i tip-specifična polja
        (npr. <code>text</code> za pasus/naslov, <code>image: {img, imgDesc}</code> za sliku, <code>items: []</code> za listu).
      </div>
    </div>
  </div>

  <button type="submit" class="btn btn-primary">Sačuvaj</button>
</form>
