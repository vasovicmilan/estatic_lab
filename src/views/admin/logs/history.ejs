<%- include("../../includes/head") %>
<%- include("../../includes/navigation") %>

<main class="container-fluid py-4">
  <%- include("../../includes/breadcrumbs") %>

  <h1 class="h3 mb-4">Istorija logova</h1>

  <div class="card">
    <div class="card-body p-0">
      <% if (data.items.length === 0) { %>
        <p class="text-muted p-3 mb-0">Nema sačuvanih dnevnih izveštaja još uvek.</p>
      <% } else { %>
        <table class="table mb-0">
          <thead><tr><th>Datum</th><th>Ukupno zahteva</th><th>Greške</th><th>Prosečno vreme</th><th></th></tr></thead>
          <tbody>
            <% data.items.forEach(function(item) { %>
              <tr>
                <td><%= item.date %></td>
                <td><%= item.ukupnoZahteva %></td>
                <td><%= item.greske %></td>
                <td><%= item.prosecnoVreme %></td>
                <td><a href="<%= item.detailUrl %>" class="btn btn-sm btn-outline-secondary">Detalji</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <%- include("../../includes/pagination", { pagination: data.pagination }) %>
</main>

<%- include("../../includes/footer") %>