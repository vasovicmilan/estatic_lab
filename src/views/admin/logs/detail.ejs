<%- include("../../includes/head") %>
<%- include("../../includes/navigation") %>

<main class="container-fluid py-4">
  <%- include("../../includes/breadcrumbs") %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Log izveštaj - <%= data.summary.date %></h1>
    <a href="<%= data.backUrl %>" class="btn btn-outline-secondary btn-sm">&larr; Nazad na istoriju</a>
  </div>

  <% if (!data.summary) { %>
    <div class="alert alert-warning">Nema podataka za prikaz.</div>
  <% } else { %>
    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">Ukupno zahteva</p>
          <p class="h4 mb-0"><%= data.summary.requests.total %></p>
        </div></div>
      </div>
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">Jedinstvenih IP adresa</p>
          <p class="h4 mb-0"><%= data.summary.requests.uniqueIPs %></p>
        </div></div>
      </div>
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">Upozorenja / Greške</p>
          <p class="h4 mb-0"><%= data.summary.logs.warnCount %> / <%= data.summary.logs.errorCount %></p>
        </div></div>
      </div>
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">Prosečno vreme odgovora</p>
          <p class="h4 mb-0"><%= data.summary.performance ? data.summary.performance.avgResponseTimeMs + " ms" : "-" %></p>
        </div></div>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">2xx</p><p class="h5 mb-0"><%= data.summary.requests.byStatusClass["2xx"] %></p>
        </div></div>
      </div>
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">3xx</p><p class="h5 mb-0"><%= data.summary.requests.byStatusClass["3xx"] %></p>
        </div></div>
      </div>
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">4xx</p><p class="h5 mb-0"><%= data.summary.requests.byStatusClass["4xx"] %></p>
        </div></div>
      </div>
      <div class="col-md-3">
        <div class="card h-100"><div class="card-body">
          <p class="text-muted small mb-1">5xx</p><p class="h5 mb-0"><%= data.summary.requests.byStatusClass["5xx"] %></p>
        </div></div>
      </div>
    </div>

    <% if (data.summary.performance && data.summary.performance.slowestRoutes && data.summary.performance.slowestRoutes.length > 0) { %>
      <div class="card mb-4">
        <div class="card-header">Najsporije rute (po proseku)</div>
        <div class="card-body p-0">
          <table class="table table-sm mb-0">
            <thead><tr><th>Ruta</th><th class="text-end">Prosečno vreme</th><th class="text-end">Broj zahteva</th></tr></thead>
            <tbody>
              <% data.summary.performance.slowestRoutes.forEach(function(r) { %>
                <tr><td><%= r.label %></td><td class="text-end"><%= r.avgMs %> ms</td><td class="text-end"><%= r.count %></td></tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-header">Najčešće greške</div>
          <div class="card-body p-0">
            <% if (data.summary.topErrors.length === 0) { %>
              <p class="text-muted p-3 mb-0">Nema zabeleženih grešaka.</p>
            <% } else { %>
              <table class="table table-sm mb-0"><tbody>
                <% data.summary.topErrors.forEach(function(e) { %>
                  <tr><td><%= e.label %></td><td class="text-end"><%= e.count %></td></tr>
                <% }) %>
              </tbody></table>
            <% } %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-header">Najposećenije rute</div>
          <div class="card-body p-0">
            <% if (data.summary.topUrls.length === 0) { %>
              <p class="text-muted p-3 mb-0">Nema podataka.</p>
            <% } else { %>
              <table class="table table-sm mb-0"><tbody>
                <% data.summary.topUrls.forEach(function(u) { %>
                  <tr><td><%= u.label %></td><td class="text-end"><%= u.count %></td></tr>
                <% }) %>
              </tbody></table>
            <% } %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-header">Rute sa 4xx/5xx odgovorima</div>
          <div class="card-body p-0">
            <% if (data.summary.topErrorUrls.length === 0) { %>
              <p class="text-muted p-3 mb-0">Nema neuspešnih zahteva.</p>
            <% } else { %>
              <table class="table table-sm mb-0"><tbody>
                <% data.summary.topErrorUrls.forEach(function(u) { %>
                  <tr><td><%= u.label %></td><td class="text-end"><%= u.count %></td></tr>
                <% }) %>
              </tbody></table>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</main>

<%- include("../../includes/footer") %>