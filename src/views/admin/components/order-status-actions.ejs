<% const d = data; %>
<% if (!d.actions || d.actions.length === 0) { %>
  <p class="text-muted small mb-0">Nema dostupnih akcija za trenutni status.</p>
<% } else { %>
  <div class="d-flex flex-column gap-2">
    <% d.actions.forEach(function(action, index) { %>
      <% if (action.needsReason) { %>
        <button type="button" class="btn btn-<%= action.variant %> btn-sm" data-bs-toggle="modal" data-bs-target="#reasonModal<%= index %>">
          <%= action.label %>
        </button>
        <div class="modal fade" id="reasonModal<%= index %>" tabindex="-1">
          <div class="modal-dialog">
            <form action="<%= action.url %>" method="POST">
              <input type="hidden" name="_method" value="PUT">
              <input type="hidden" name="CSRFToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title"><%= action.label %></h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                  <label class="form-label">Razlog (opciono)</label>
                  <textarea name="reason" class="form-control" rows="3"></textarea>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Otkaži</button>
                  <button type="submit" class="btn btn-<%= action.variant %> btn-sm">Potvrdi</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      <% } else { %>
        <form action="<%= action.url %>" method="POST" data-confirm="Da li ste sigurni?">
          <input type="hidden" name="_method" value="PUT">
          <input type="hidden" name="CSRFToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-<%= action.variant %> btn-sm w-100"><%= action.label %></button>
        </form>
      <% } %>
    <% }) %>
  </div>
<% } %>