<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container-fluid py-4">
  <%- include("../includes/breadcrumbs") %>
  <%- include("../includes/flash-messages") %>

  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="h3 mb-0"><%= pageTitle %></h1>
    <div class="d-flex gap-2">
      <% if (data.topbar && data.topbar.searchUrl) { %>
        <%- include("../includes/components/search", { search: data.topbar.search }) %>
      <% } %>
      <% if (data.topbar && data.topbar.createUrl) { %>
        <a href="<%= data.topbar.createUrl %>" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg"></i> <%= data.topbar.createLabel || "Dodaj" %>
        </a>
      <% } %>
    </div>
  </div>

  <% if (data.topbar && data.topbar.filters && data.topbar.filters.length > 0) { %>
    <div class="card mb-4">
      <div class="card-body">
        <form method="GET" class="row g-3 align-items-end">
          <% data.topbar.filters.forEach(function(filter) { %>
            <div class="col-auto">
              <label class="form-label small text-muted"><%= filter.label %></label>
              <% if (filter.type === 'select') { %>
                <select name="<%= filter.name %>" class="form-select form-select-sm" onchange="this.form.submit()">
                  <% filter.options.forEach(function(opt) { %>
                    <option value="<%= opt.value %>" <%= filter.value === opt.value ? 'selected' : '' %>><%= opt.label %></option>
                  <% }) %>
                </select>
              <% } else { %>
                <input type="text" name="<%= filter.name %>" class="form-control form-control-sm" value="<%= filter.value || '' %>">
              <% } %>
            </div>
          <% }) %>
          <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary btn-sm">Primeni</button>
            <a href="<%= data.pagination.basePath %>" class="btn btn-outline-secondary btn-sm">Resetuj</a>
          </div>
        </form>
      </div>
    </div>
  <% } %>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <% data.columns.forEach(function(col) { %>
              <th><%= col.label %></th>
            <% }) %>
            <% if (data.actions && data.actions.length > 0) { %><th class="text-end">Akcije</th><% } %>
          </tr>
        </thead>
        <tbody>
          <% if (data.items.length === 0) { %>
            <tr><td colspan="<%= data.columns.length + 1 %>" class="text-center text-muted py-4">Nema podataka za prikaz</td></tr>
          <% } %>
          <% data.items.forEach(function(item) { %>
            <tr>
              <% data.columns.forEach(function(col) {
                   const val = Array.isArray(item[col.key]) ? item[col.key].join(", ") : item[col.key];
              %>
                <td><% if (val !== undefined && val !== null && val !== "") { %><%= val %><% } else { %><span class="text-muted">&mdash;</span><% } %></td>
              <% }) %>
              <% if (data.actions && data.actions.length > 0) { %>
                <td class="text-end text-nowrap">
                  <% data.actions.forEach(function(action) { %>
                    <% if (action.type === 'view') { %>
                      <a href="<%= action.url %><%= item.id %>" class="btn btn-sm btn-outline-secondary" title="Detalji"><i class="bi bi-eye"></i></a>
                    <% } else if (action.type === 'edit') { %>
                      <a href="<%= action.url.replace('/detalji/', '/izmena/') %><%= item.id %>" class="btn btn-sm btn-outline-warning" title="Izmeni"><i class="bi bi-pencil"></i></a>
                    <% } else if (action.type === 'delete') { %>
                      <form action="<%= action.url %><%= item.id %>" method="POST" class="d-inline" data-confirm="Da li ste sigurni da zelite da obrisete ovu stavku?">
                        <input type="hidden" name="_method" value="DELETE">
                        <input type="hidden" name="CSRFToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Obrisi"><i class="bi bi-trash"></i></button>
                      </form>
                    <% } %>
                  <% }) %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include("../includes/pagination", { pagination: data.pagination }) %>
</main>

<%- include("../includes/footer") %>
