<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container-fluid py-4">
  <%- include("../includes/breadcrumbs") %>
  <%- include("../includes/flash-messages") %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><%= pageTitle %></h1>
    <a href="<%= data.backUrl %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Nazad</a>
  </div>

  <% if (data.errors && data.errors.general) { %>
    <div class="alert alert-danger"><%= data.errors.general %></div>
  <% } %>

  <%- include(`forms/${data.formType}`, { data: data, csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '' }) %>
</main>

<%- include("../includes/footer") %>
