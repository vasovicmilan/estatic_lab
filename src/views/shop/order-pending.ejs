<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/flash-messages") %>

  <div class="row justify-content-center text-center">
    <div class="col-md-7">
      <i class="bi bi-envelope-check display-3 text-primary mb-3"></i>
      <h1 class="h3 mb-3">Potvrdite porudžbinu</h1>
      <p class="text-muted">
        Poslali smo email na <strong><%= data.email %></strong> sa linkom za potvrdu porudžbine.
        Kliknite na link u emailu da biste je finalizovali.
      </p>
      <% if (data.tokenExpiration) { %>
        <p class="text-muted small">Link važi do: <%= new Date(data.tokenExpiration).toLocaleString("sr-RS") %></p>
      <% } %>
      <a href="/" class="btn btn-outline-primary mt-3">Nazad na početnu</a>
    </div>
  </div>
</main>

<%- include("../includes/footer") %>