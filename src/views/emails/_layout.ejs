<!--
  Shared wrapper for every transactional email. Included by each content template via
  the include() helper, passing title/preheader/body (body is raw already-rendered
  HTML, not further EJS-escaped). Table-based layout + inline styles on purpose -
  this needs to render consistently in email clients that ignore <style> blocks
  (Outlook desktop, some webmail).
-->
<!DOCTYPE html>
<html lang="sr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body style="margin:0; padding:0; background-color:#f4f2f0; font-family:Arial, Helvetica, sans-serif;">
  <span style="display:none; max-height:0; overflow:hidden;"><%= typeof preheader !== 'undefined' ? preheader : '' %></span>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f2f0; padding:32px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; background-color:#ffffff; border-radius:8px; overflow:hidden;">
          <tr>
            <td style="background-color:#7a5c3e; padding:24px 32px;">
              <span style="color:#ffffff; font-size:20px; font-weight:bold;"><%= SITE_NAME %></span>
            </td>
          </tr>
          <tr>
            <td style="padding:32px;">
              <%- body %>
            </td>
          </tr>
          <tr>
            <td style="padding:20px 32px; background-color:#f9f7f5; border-top:1px solid #eee;">
              <p style="margin:0; font-size:12px; color:#888;">
                <%= SITE_NAME %> &middot; Pitanja? Pišite nam na <a href="mailto:<%= SUPPORT_EMAIL %>" style="color:#7a5c3e;"><%= SUPPORT_EMAIL %></a>
              </p>
              <p style="margin:8px 0 0; font-size:12px; color:#aaa;">&copy; <%= currentYear %> <%= SITE_NAME %>. Sva prava zadržana.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>