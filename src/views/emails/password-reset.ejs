<%
  const heading = isAccountClaim ? "Vaš termin je zakazan!" : "Reset lozinke";
  const intro = isAccountClaim
    ? "Kreirali smo vam nalog kako biste mogli da pratite vaš termin. Postavite lozinku da preuzmete nalog."
    : "Zatražili ste reset lozinke. Kliknite dugme ispod da postavite novu lozinku.";
  const buttonLabel = isAccountClaim ? "Preuzmi nalog" : "Postavi novu lozinku";
%>
<%- include("_layout", {
  title: heading,
  preheader: intro,
  body: `
    <h1 style="font-size:20px; color:#333; margin:0 0 16px;">${heading}${typeof firstName !== 'undefined' && firstName ? ', ' + firstName : ''}</h1>
    <p style="font-size:14px; color:#555; line-height:1.6; margin:0 0 16px;">${intro}</p>
    <p style="text-align:center; margin:32px 0;">
      <a href="${resetUrl}" style="background-color:#7a5c3e; color:#ffffff; padding:12px 28px; border-radius:4px; text-decoration:none; font-size:14px; font-weight:bold; display:inline-block;">${buttonLabel}</a>
    </p>
    <p style="font-size:12px; color:#999; line-height:1.6; margin:0;">
      Ako niste vi zatražili ovo, slobodno zanemarite ovaj email — vaša lozinka ostaje nepromenjena.<br>
      Ako dugme ne radi, kopirajte ovaj link u vaš pregledač:<br>
      <a href="${resetUrl}" style="color:#7a5c3e; word-break:break-all;">${resetUrl}</a>
    </p>
  `
}) %>