<%- include("_layout", {
  title: "Vaš paket je aktiviran",
  preheader: "Vaš paket tretmana je spreman za korišćenje",
  body: `
    <h1 style="font-size:20px; color:#333; margin:0 0 16px;">Vaš paket je aktiviran${typeof firstName !== 'undefined' && firstName ? ', ' + firstName : ''}!</h1>
    <p style="font-size:14px; color:#555; line-height:1.6; margin:0 0 16px;">
      Vaš paket tretmana je zaveden i spreman za korišćenje. Termine u okviru paketa zakazujete kao i obično -
      javite terapeutu da plaćate iz paketa.
    </p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f9f7f5; border-radius:6px; margin:0 0 16px;">
      <tr><td style="padding:16px; font-size:14px; color:#333;">
        <strong>Paket:</strong> ${purchase.paket || "-"}<br>
        <strong>Plaćeno:</strong> ${purchase.placeno != null ? purchase.placeno + " RSD" : "-"}
        ${purchase.istice ? `<br><strong>Važi do:</strong> ${purchase.istice}` : ""}
      </td></tr>
    </table>
    <p style="text-align:center; margin:32px 0;">
      <a href="${manageUrl}" style="background-color:#7a5c3e; color:#ffffff; padding:12px 28px; border-radius:4px; text-decoration:none; font-size:14px; font-weight:bold; display:inline-block;">Zakaži termin</a>
    </p>
  `
}) %>