<%
  function rows(items, emptyText) {
    if (!items || !items.length) return `<tr><td style="padding:8px 16px; color:#999; font-size:13px;">${emptyText}</td></tr>`;
    return items.map(function(item) {
      return `<tr>
        <td style="padding:6px 16px; font-size:13px; color:#333; border-bottom:1px solid #eee;">${item.label}</td>
        <td style="padding:6px 16px; font-size:13px; color:#333; border-bottom:1px solid #eee; text-align:right;">${item.count}</td>
      </tr>`;
    }).join("");
  }

  function perfRows(items, emptyText) {
    if (!items || !items.length) return `<tr><td style="padding:8px 16px; color:#999; font-size:13px;">${emptyText}</td></tr>`;
    return items.map(function(item) {
      return `<tr>
        <td style="padding:6px 16px; font-size:13px; color:#333; border-bottom:1px solid #eee;">${item.label}</td>
        <td style="padding:6px 16px; font-size:13px; color:#333; border-bottom:1px solid #eee; text-align:right;">${item.avgMs} ms</td>
        <td style="padding:6px 16px; font-size:13px; color:#999; border-bottom:1px solid #eee; text-align:right;">${item.count}x</td>
      </tr>`;
    }).join("");
  }
%>
<%- include("_layout", {
  title: `${periodLabel} - izveštaj sa sajta`,
  preheader: `${periodLabel} za period ${dateRangeLabel}`,
  body: `
    <h1 style="font-size:20px; color:#333; margin:0 0 4px;">${periodLabel}</h1>
    <p style="font-size:13px; color:#999; margin:0 0 16px;">Period: ${dateRangeLabel}</p>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f9f7f5; border-radius:6px; margin:0 0 20px;">
      <tr>
        <td style="padding:16px; font-size:14px; color:#333; width:50%;">
          <strong>Ukupno zahteva:</strong> ${requests.total}<br>
          <strong>Jedinstvenih IP adresa:</strong> ${requests.uniqueIPs}<br>
          <strong>2xx (uspešno):</strong> ${requests.byStatusClass["2xx"]}<br>
          <strong>3xx (redirekcije):</strong> ${requests.byStatusClass["3xx"]}
        </td>
        <td style="padding:16px; font-size:14px; color:#333; width:50%;">
          <strong>4xx (greške klijenta):</strong> ${requests.byStatusClass["4xx"]}<br>
          <strong>5xx (greške servera):</strong> ${requests.byStatusClass["5xx"]}<br>
          <strong>Upozorenja (warn):</strong> ${logs.warnCount}<br>
          <strong>Greške (error):</strong> ${logs.errorCount}
        </td>
      </tr>
    </table>

    ${(typeof perf !== "undefined" && perf) ? `
    <h2 style="font-size:15px; color:#333; margin:0 0 8px;">Performanse</h2>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f9f7f5; border-radius:6px; margin:0 0 20px;">
      <tr>
        <td style="padding:16px; font-size:14px; color:#333; width:50%;">
          <strong>Prosečno vreme odgovora:</strong> ${perf.avgResponseTimeMs} ms
        </td>
        <td style="padding:16px; font-size:14px; color:#333; width:50%;">
          <strong>Najsporiji odgovor:</strong> ${perf.maxResponseTimeMs} ms${perf.maxResponseTimeUrl ? ` (${perf.maxResponseTimeUrl})` : ""}
        </td>
      </tr>
    </table>

    <h2 style="font-size:15px; color:#333; margin:0 0 8px;">Najsporije rute (po proseku)</h2>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 20px; border:1px solid #eee; border-radius:4px;">
      ${perfRows(perf.slowestRoutes, "Nema dovoljno podataka za ovaj period.")}
    </table>
    ` : ""}

    <h2 style="font-size:15px; color:#333; margin:0 0 8px;">Najčešće greške</h2>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 20px; border:1px solid #eee; border-radius:4px;">
      ${rows(topErrors, "Nema zabeleženih grešaka za ovaj period.")}
    </table>

    <h2 style="font-size:15px; color:#333; margin:0 0 8px;">Najposećenije rute</h2>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 20px; border:1px solid #eee; border-radius:4px;">
      ${rows(topUrls, "Nema podataka o saobraćaju za ovaj period.")}
    </table>

    <h2 style="font-size:15px; color:#333; margin:0 0 8px;">Rute sa najviše 4xx/5xx odgovora</h2>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 8px; border:1px solid #eee; border-radius:4px;">
      ${rows(topErrorUrls, "Nema neuspešnih zahteva za ovaj period.")}
    </table>
  `
}) %>