<%- include("_layout", {
  title: "Potvrdite vaš nalog",
  preheader: "Kliknite da potvrdite vašu email adresu",
  body: `
    <h1 style="font-size:20px; color:#333; margin:0 0 16px;">Dobrodošli${typeof firstName !== 'undefined' && firstName ? ', ' + firstName : ''}!</h1>
    <p style="font-size:14px; color:#555; line-height:1.6; margin:0 0 16px;">
      Hvala što ste se registrovali. Kliknite dugme ispod da potvrdite svoju email adresu i aktivirate nalog.
    </p>
    <p style="text-align:center; margin:32px 0;">
      <a href="${confirmationUrl}" style="background-color:#7a5c3e; color:#ffffff; padding:12px 28px; border-radius:4px; text-decoration:none; font-size:14px; font-weight:bold; display:inline-block;">Potvrdi nalog</a>
    </p>
    <p style="font-size:12px; color:#999; line-height:1.6; margin:0;">
      Ako dugme ne radi, kopirajte ovaj link u vaš pregledač:<br>
      <a href="${confirmationUrl}" style="color:#7a5c3e; word-break:break-all;">${confirmationUrl}</a>
    </p>
  `
}) %>