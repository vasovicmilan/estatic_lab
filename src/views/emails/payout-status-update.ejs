<%- include("_layout", {
  title: "Status zahteva za isplatu ažuriran",
  preheader: `Vaš zahtev za isplatu je ažuriran: ${status}`,
  body: `
    <h1 style="font-size:20px; color:#333; margin:0 0 16px;">Status zahteva za isplatu ažuriran${typeof firstName !== 'undefined' && firstName ? ', ' + firstName : ''}</h1>
    <p style="font-size:14px; color:#555; line-height:1.6; margin:0 0 16px;">
      Novi status vašeg zahteva za isplatu: <strong>${status}</strong>
    </p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f9f7f5; border-radius:6px; margin:0 0 16px;">
      <tr><td style="padding:16px; font-size:14px; color:#333;">
        <strong>Iznos:</strong> ${payoutRequest.amount} RSD
      </td></tr>
    </table>
    ${payoutRequest.adminNote ? `<p style="font-size:14px; color:#555; line-height:1.6; margin:0 0 16px;"><strong>Napomena:</strong> ${payoutRequest.adminNote}</p>` : ""}
    <p style="font-size:14px; color:#555; line-height:1.6; margin:0;">
      Detalje možete pratiti na svom partnerskom nalogu. Ako imate pitanja, slobodno nas kontaktirajte na <a href="mailto:${SUPPORT_EMAIL}" style="color:#7a5c3e;">${SUPPORT_EMAIL}</a>.
    </p>
  `
}) %>