<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/flash-messages") %>
  <h1 class="h3 mb-4">Detalji termina</h1>

  <div class="row g-4">
    <div class="col-md-7">
      <div class="card">
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-4 text-muted">Klijent</dt><dd class="col-8"><%= data.appointment.klijent.ime %></dd>
            <dt class="col-4 text-muted">Email</dt><dd class="col-8"><%= data.appointment.klijent.email %></dd>
            <dt class="col-4 text-muted">Telefon</dt><dd class="col-8"><%= data.appointment.klijent.telefon || "-" %></dd>
            <dt class="col-4 text-muted">Usluga</dt><dd class="col-8"><%= data.appointment.usluga.naziv %></dd>
            <dt class="col-4 text-muted">Trajanje</dt><dd class="col-8"><%= data.appointment.usluga.trajanje %></dd>
            <dt class="col-4 text-muted">Termin</dt><dd class="col-8"><%= data.appointment.termin.pocetak %> - <%= data.appointment.termin.kraj %></dd>
            <dt class="col-4 text-muted">Status</dt><dd class="col-8"><%= data.appointment.status %></dd>
            <dt class="col-4 text-muted">Cena</dt><dd class="col-8"><%= data.appointment.konacnaCena %></dd>
            <% if (data.appointment.napomenaKlijenta) { %><dt class="col-4 text-muted">Napomena</dt><dd class="col-8"><%= data.appointment.napomenaKlijenta %></dd><% } %>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-md-5">
      <div class="card">
        <div class="card-body d-flex flex-column gap-2">
          <% if (data.canConfirm) { %>
            <form action="/moj-nalog/termini/<%= data.appointment.id %>/potvrdi" method="POST">
              <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-success w-100">Potvrdi</button>
            </form>
          <% } %>
          <% if (data.canReject) { %>
            <button type="button" class="btn btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#rejectModal">Odbij</button>
            <div class="modal fade" id="rejectModal" tabindex="-1">
              <div class="modal-dialog">
                <form action="/moj-nalog/termini/<%= data.appointment.id %>/odbij" method="POST">
                  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
                  <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Odbij termin</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                      <label class="form-label">Razlog (opciono)</label>
                      <textarea name="reason" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Otkaži</button>
                      <button type="submit" class="btn btn-danger btn-sm">Potvrdi odbijanje</button>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          <% } %>
          <% if (data.canComplete) { %>
            <form action="/moj-nalog/termini/<%= data.appointment.id %>/zavrsi" method="POST">
              <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-primary w-100">Označi kao završen</button>
            </form>
          <% } %>
          <% if (data.canNoShow) { %>
            <button type="button" class="btn btn-outline-warning w-100" data-bs-toggle="modal" data-bs-target="#noShowModal">Klijent se nije pojavio</button>
            <div class="modal fade" id="noShowModal" tabindex="-1">
              <div class="modal-dialog">
                <form action="/moj-nalog/termini/<%= data.appointment.id %>/nije-se-pojavio" method="POST">
                  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
                  <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Klijent se nije pojavio</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                      <label class="form-label">Napomena (opciono)</label>
                      <textarea name="note" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Otkaži</button>
                      <button type="submit" class="btn btn-warning btn-sm">Potvrdi</button>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          <% } %>
          <a href="<%= data.backUrl %>" class="btn btn-outline-secondary w-100">Nazad</a>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include("../includes/footer") %>