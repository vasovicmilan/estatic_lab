<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/flash-messages") %>
  <h1 class="h3 mb-4">Moj profil</h1>

  <%- include("../includes/components/employee-nav", { currentPath: "/moj-nalog/profil", isCommissionBased: data.isCommissionBased }) %>

  <div class="row g-4">
    <div class="col-md-5">
      <div class="card">
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-5 text-muted">Ime</dt><dd class="col-7"><%= data.employee.imePrezime %></dd>
            <dt class="col-5 text-muted">Email</dt><dd class="col-7"><%= data.employee.email %></dd>
            <dt class="col-5 text-muted">Telefon</dt><dd class="col-7"><%= data.employee.telefon || "-" %></dd>
            <dt class="col-5 text-muted">Usluge</dt><dd class="col-7"><%= (data.employee.usluge || []).join(", ") || "-" %></dd>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-md-7">
      <div class="card">
        <div class="card-header"><h2 class="h6 mb-0">Radno vreme</h2></div>
        <div class="card-body">
          <form action="<%= data.workingHoursEditUrl %>" method="POST">
            <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">

            <input type="hidden" name="workingHours" value='<%- JSON.stringify(data.employee.workingHoursRaw || []) %>' data-repeater-input="workingHours">
            <div class="border rounded p-3"
                 data-schedule="workingHours"
                 data-schedule-days='<%- JSON.stringify(data.scheduleDays || []) %>'
                 data-schedule-value='<%- JSON.stringify(data.employee.workingHoursRaw || []) %>'>
              <div data-schedule-days-list></div>
            </div>

            <div class="form-text mt-2">Za svaki dan dodajte jedan ili više termina rada. Dani bez termina se tretiraju kao neradni.</div>
            <button type="submit" class="btn btn-primary mt-3">Sačuvaj radno vreme</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>

<script src="/js/admin-schedule.js"></script>

<%- include("../includes/footer") %>