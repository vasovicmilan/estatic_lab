<footer class="bg-dark text-light py-5 mt-auto">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-4">
        <h5 class="fw-bold">Estatic Lab</h5>
        <p class="text-secondary small">Vaš prostor za opuštanje i negu.</p>
      </div>
      <div class="col-md-4">
        <h6>Brzi linkovi</h6>
        <ul class="list-unstyled small">
          <li><a href="/usluge" class="text-secondary text-decoration-none">Usluge</a></li>
          <li><a href="/paketi" class="text-secondary text-decoration-none">Paketi</a></li>
          <li><a href="/blog" class="text-secondary text-decoration-none">Blog</a></li>
          <li><a href="/nas-tim" class="text-secondary text-decoration-none">Naš tim</a></li>
          <li><a href="/kontakt" class="text-secondary text-decoration-none">Kontakt</a></li>
          <li><a href="/o-nama" class="text-secondary text-decoration-none">O nama</a></li>
        </ul>
      </div>
      <div class="col-md-4">
        <h6>Prijavite se na newsletter</h6>
        <form action="/newsletter/prijava" method="POST" class="d-flex gap-2">
          <input type="text" name="nickname" class="d-none" tabindex="-1" autocomplete="off">
          <input type="email" name="email" class="form-control form-control-sm" placeholder="vas@email.com" required>
          <input type="hidden" name="CSRFToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-primary btn-sm text-nowrap">Prijavi se</button>
        </form>
        <div class="mt-3 small text-secondary">
          <a href="/politika-privatnosti" class="text-secondary text-decoration-none">Politika privatnosti</a>
          &middot;
          <a href="/uslovi-koriscenja" class="text-secondary text-decoration-none">Uslovi korišćenja</a>
        </div>
      </div>
    </div>
    <hr class="border-secondary">
    <p class="text-secondary small mb-0">&copy; <%= new Date().getFullYear() %> Estatic Lab. Sva prava zadržana.</p>
  </div>
</footer>

<!-- Shared confirmation modal — used by every form with a data-confirm="..." attribute
     (delete buttons, cancel appointment, deactivate account, etc.) via main.js -->
<div class="modal fade" id="confirmActionModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Potvrda</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
      </div>
      <div class="modal-body">
        <p id="confirmActionMessage" class="mb-0"></p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Otkaži</button>
        <button type="button" class="btn btn-danger" id="confirmActionButton">Potvrdi</button>
      </div>
    </div>
  </div>
</div>

<!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> -->
<script src="/js/main.js"></script>
</body>
</html>