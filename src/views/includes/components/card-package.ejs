<div class="card h-100 shadow-sm <%= pkg.najbolji ? 'border-primary' : '' %>">
  <% if (pkg.slika && pkg.slika.url) { %>
    <img src="<%= pkg.slika.url %>" class="card-img-top package-card-img" alt="<%= pkg.slika.alt || pkg.naziv %>">
  <% } %>
  <div class="card-body d-flex flex-column">
    <% if (pkg.najbolji || pkg.oznaka) { %>
      <span class="badge text-bg-primary mb-2 align-self-start"><%= pkg.oznaka || "Najbolja vrednost" %></span>
    <% } %>
    <h3 class="h5"><a href="/paketi/<%= pkg.slug %>" class="text-decoration-none text-dark"><%= pkg.naziv %></a></h3>
    <p class="text-muted small flex-grow-1"><%= pkg.kratakOpis %></p>

    <% if (pkg.stavke && pkg.stavke.length > 0) { %>
      <ul class="list-unstyled small mb-3">
        <% pkg.stavke.forEach(function(stavka) { %>
          <li><i class="bi bi-check2 text-primary me-1"></i><%= stavka %></li>
        <% }) %>
      </ul>
    <% } %>

    <div class="d-flex justify-content-between align-items-center mt-auto">
      <div>
        <strong><%= pkg.cena %></strong>
        <% if (pkg.staraCena) { %><span class="text-muted text-decoration-line-through small ms-1"><%= pkg.staraCena %></span><% } %>
      </div>
      <a href="/paketi/<%= pkg.slug %>" class="btn btn-outline-primary btn-sm">Detalji</a>
    </div>
  </div>
</div>