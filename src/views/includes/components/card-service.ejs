<div class="card h-100 shadow-sm">
  <% if (service.slika && service.slika.url) { %>
    <img src="<%= service.slika.url %>" class="card-img-top" alt="<%= service.slika.alt || service.naziv %>" style="height:200px;object-fit:cover;">
  <% } %>
  <div class="card-body d-flex flex-column">
    <% if (service.istaknuto) { %><span class="badge bg-primary mb-2 align-self-start">Istaknuto</span><% } %>
    <h3 class="h5"><a href="/usluge/<%= service.slug %>" class="text-decoration-none text-dark"><%= service.naziv %></a></h3>
    <p class="text-muted small flex-grow-1"><%= service.kratakOpis %></p>
    <div class="d-flex justify-content-between align-items-center mt-2">
      <strong><%= service.cena %></strong>
      <a href="/usluge/<%= service.slug %>" class="btn btn-outline-primary btn-sm"><%= service.cta || "Detalji" %></a>
    </div>
  </div>
</div>
