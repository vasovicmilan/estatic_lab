<div class="card h-100 shadow-sm text-center">
  <% if (expert.slika && expert.slika.url) { %>
    <img src="<%= expert.slika.url %>" class="card-img-top" alt="<%= expert.slika.alt || expert.imePrezime %>" style="height:260px;object-fit:cover;">
  <% } %>
  <div class="card-body">
    <h3 class="h6 mb-1"><a href="/nas-tim/<%= expert.slug %>" class="text-decoration-none text-dark"><%= expert.imePrezime %></a></h3>
    <div class="text-muted small mb-2"><%= expert.titula %></div>
    <p class="small"><%= expert.kratkaBiografija %></p>
  </div>
</div>
