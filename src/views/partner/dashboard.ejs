<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-5">
  <%- include("../includes/flash-messages") %>

  <h1 class="h3 mb-4">Moj partnerski nalog</h1>
  <%- include("../includes/components/partner-nav") %>

  <div class="row g-4 mb-4">
    <div class="col-md-3">
      <div class="card h-100"><div class="card-body">
        <p class="text-muted small mb-1">Ukupno zarađeno</p>
        <p class="h4 mb-0"><%= data.balance.earned %> RSD</p>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card h-100"><div class="card-body">
        <p class="text-muted small mb-1">Isplaćeno</p>
        <p class="h4 mb-0"><%= data.balance.paid %> RSD</p>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card h-100"><div class="card-body">
        <p class="text-muted small mb-1">Rezervisano (na čekanju)</p>
        <p class="h4 mb-0"><%= data.balance.reserved %> RSD</p>
      </div></div>
    </div>
    <div class="col-md-3">
      <div class="card h-100 border-primary"><div class="card-body">
        <p class="text-muted small mb-1">Raspoloživo za isplatu</p>
        <p class="h4 mb-0 text-primary"><%= data.balance.available %> RSD</p>
      </div></div>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header">Zatraži isplatu</div>
        <div class="card-body">
          <% if (data.balance.available <= 0) { %>
            <p class="text-muted mb-0">Trenutno nemate raspoloživ iznos za isplatu.</p>
          <% } else { %>
            <form action="/moj-partner-nalog/isplata" method="POST" class="d-flex gap-2">
              <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
              <input type="number" name="amount" class="form-control" min="1" max="<%= data.balance.available %>" step="0.01" placeholder="Iznos u RSD" required>
              <button type="submit" class="btn btn-primary text-nowrap">Pošalji zahtev</button>
            </form>
            <small class="text-muted d-block mt-2">Najviše <%= data.balance.available %> RSD.</small>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header">Vaš referalni link</div>
        <div class="card-body">
          <% if (data.referralLinks.length === 0) { %>
            <p class="text-muted mb-2">Nemate aktivan referalni kod. Kontaktirajte administratora.</p>
          <% } else { %>
            <% data.referralLinks.forEach(function(ref) { %>
              <div class="mb-3">
                <p class="small text-muted mb-1"><%= ref.opis %></p>
                <div class="input-group">
                  <input type="text" class="form-control form-control-sm" value="<%= ref.link %>" readonly data-referral-link-input>
                  <button type="button" class="btn btn-outline-secondary btn-sm" data-copy-link-btn>Kopiraj</button>
                </div>
              </div>
            <% }) %>
          <% } %>
          <a href="/moj-partner-nalog/katalog" class="small">Pogledaj sve linkove po uslugama/proizvodima &rarr;</a>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span>Poslednje provizije</span>
      <a href="/moj-partner-nalog/provizije" class="small">Sve provizije &rarr;</a>
    </div>
    <div class="card-body p-0">
      <% if (data.recentCommissions.length === 0) { %>
        <p class="text-muted p-3 mb-0">Još uvek nemate zabeleženu proviziju.</p>
      <% } else { %>
        <table class="table mb-0">
          <thead><tr><th>Izvor</th><th>Osnovna vrednost</th><th>Procenat</th><th>Iznos</th><th>Status</th></tr></thead>
          <tbody>
            <% data.recentCommissions.forEach(function(c) { %>
              <tr>
                <td><%= c.izvor %></td>
                <td><%= c.osnovnaVrednost %></td>
                <td><%= c.procenat %></td>
                <td><%= c.iznos %></td>
                <td><%= c.status %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</main>

<%- include("../includes/footer") %>