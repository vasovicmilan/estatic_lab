<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<header class="position-relative text-white hero-section <%= data.hero.image ? 'hero-section-with-image' : '' %>">
  <div class="container hero-inner">
    <div class="row align-items-center hero-inner">
      <div class="col-lg-7 py-5">
        <p class="text-uppercase small fw-semibold mb-2 hero-eyebrow"><%= data.hero.eyebrow %></p>
        <h1 class="display-4 fw-bold mb-3"><%= data.hero.title %></h1>
        <p class="lead mb-4"><%= data.hero.subtitle %></p>
        <div class="d-flex flex-wrap gap-3">
          <a href="<%= data.hero.ctaUrl %>" class="btn btn-primary btn-lg"><%= data.hero.ctaLabel %></a>
          <a href="<%= data.hero.secondaryCtaUrl %>" class="btn btn-outline-light btn-lg"><%= data.hero.secondaryCtaLabel %></a>
        </div>
      </div>
    </div>
  </div>
</header>

<main>
  <%- include("../includes/flash-messages") %>

  <!-- Why us -->
  <% if (data.whyUs && data.whyUs.length > 0) { %>
    <section class="container py-5">
      <div class="row g-4 text-center">
        <% data.whyUs.forEach(function(item) { %>
          <div class="col-6 col-md-3">
            <i class="bi <%= item.icon %> display-6 text-primary d-block mb-2"></i>
            <h3 class="h6"><%= item.title %></h3>
            <p class="text-muted small"><%= item.text %></p>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

    <% if (data.intro) { %>
    <section class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <h2 class="h3 mb-3 text-center"><%= data.intro.title %></h2>
          <p class="lead text-center mb-4"><%= data.intro.lead %></p>
          <p class="mb-4"><%= data.intro.who %></p>

          <div class="row g-3 mb-4">
            <% data.intro.massages.forEach(function(m) { %>
              <div class="col-6 col-md-3">
                <div class="border rounded p-3 h-100 text-center">
                  <h3 class="h6 mb-1"><%= m.title %></h3>
                  <p class="text-muted small mb-0"><%= m.text %></p>
                </div>
              </div>
            <% }) %>
          </div>

          <p class="mb-4"><%= data.intro.packages %></p>
          <p class="fst-italic text-center mb-0"><%= data.intro.closing %></p>
        </div>
      </div>
    </section>
  <% } %>

  <!-- Featured services -->
  <% if (data.highlightedServices && data.highlightedServices.length > 0) { %>
    <section class="bg-light py-5">
      <div class="container">
        <h2 class="h3 mb-2 text-center">Naše usluge</h2>
        <p class="text-muted text-center mb-4">Masaže, ESMA tretmani i nega lica i tela - prilagođeno vama</p>
        <div class="row g-4">
          <% data.highlightedServices.forEach(function(service) { %>
            <div class="col-md-4">
              <%- include("../includes/components/card-service", { service: service }) %>
            </div>
          <% }) %>
        </div>
        <div class="text-center mt-4"><a href="/usluge" class="btn btn-outline-primary">Sve usluge</a></div>
      </div>
    </section>
  <% } %>

  <!-- Best packages -->
  <% if (data.bestPackages && data.bestPackages.length > 0) { %>
    <section class="container py-5">
      <h2 class="h3 mb-2 text-center">Naši paketi</h2>
      <p class="text-muted text-center mb-4">Uštedite uz pakete od više tretmana</p>
      <div class="row g-4">
        <% data.bestPackages.forEach(function(pkg) { %>
          <div class="col-md-4">
            <%- include("../includes/components/card-package", { pkg: pkg }) %>
          </div>
        <% }) %>
      </div>
      <div class="text-center mt-4"><a href="/paketi" class="btn btn-outline-primary">Svi paketi</a></div>
    </section>
  <% } %>

  <!-- Our team -->
  <% if (data.featuredExperts && data.featuredExperts.length > 0) { %>
    <section class="bg-light py-5">
      <div class="container">
        <h2 class="h3 mb-4 text-center">Naš tim</h2>
        <div class="row g-4">
          <% data.featuredExperts.forEach(function(expert) { %>
            <div class="col-md-3">
              <%- include("../includes/components/card-expert", { expert: expert }) %>
            </div>
          <% }) %>
        </div>
        <div class="text-center mt-4"><a href="/nas-tim" class="btn btn-outline-primary">Upoznajte ceo tim</a></div>
      </div>
    </section>
  <% } %>

  <!-- Social proof: testimonials + leave-a-review form -->
  <section class="container py-5">
    <h2 class="h3 mb-4 text-center">Šta kažu naši klijenti</h2>

    <% if (data.testimonials && data.testimonials.length > 0) { %>
      <div class="row g-4 mb-5">
        <% data.testimonials.forEach(function(t) { %>
          <div class="col-md-4">
            <%- include("../includes/components/card-testimonial", { testimonial: t }) %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <div class="row justify-content-center">
      <div class="col-lg-7">
        <%- include("../includes/components/testimonial-form") %>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <% if (data.latestPosts && data.latestPosts.length > 0) { %>
    <section class="bg-light py-5">
      <div class="container">
        <h2 class="h3 mb-4 text-center">Sa bloga</h2>
        <div class="row g-4">
          <% data.latestPosts.forEach(function(post) { %>
            <div class="col-md-4">
              <%- include("../includes/components/card-post", { post: post }) %>
            </div>
          <% }) %>
        </div>
        <div class="text-center mt-4"><a href="/blog" class="btn btn-outline-primary">Svi tekstovi</a></div>
      </div>
    </section>
  <% } %>

  <!-- Closing CTA -->
  <section class="py-5 text-white text-center bg-primary">
    <div class="container">
      <h2 class="h3 fw-bold mb-3">Spremni za trenutak opuštanja?</h2>
      <p class="mb-4">Zakažite svoj termin danas i prepustite se nezi koju zaslužujete.</p>
      <a href="<%= data.hero.ctaUrl %>" class="btn btn-light btn-lg">Zakažite termin</a>
    </div>
  </section>

  <!-- Location -->
  <% if (data.map && data.map.embedUrl) { %>
    <section class="container py-5">
        <h2 class="h3 mb-4 text-center">Gde se nalazimo</h2>
        <p class="text-center mt-3">
          <i class="bi bi-geo-alt-fill text-primary me-2"></i>
          <strong><%= data.map.address %></strong>
        </p>
        <div class="ratio ratio-21x9">
          <iframe
            src="<%= data.map.embedUrl %>"
            title="<%= data.map.address %>"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </section>
  <% } %>
  <% if (data.googleDataNotice) { %>
    <section class="container pb-5">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="border rounded p-3 p-md-4 bg-light small">
            <p class="mb-1"><%= data.googleDataNotice.text %></p>
            <a href="<%= data.googleDataNotice.privacyUrl %>">Pročitajte više u našoj Politici privatnosti</a>
          </div>
        </div>
      </div>
    </section>
  <% } %>
</main>

<%- include("../includes/footer") %>